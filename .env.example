# ==============================================================================
# LINKEDIN SCRAPER CONFIGURATION
# ==============================================================================
# Optional: Only needed for headless scraping if session cookies expire.
# For normal GUI usage, you log in manually once and it retains the session.
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

# ==============================================================================
# LINKEDIN OAUTH (WEBSITE LOGIN)
# ==============================================================================
# Required for user authentication on the web dashboard.
# Get these by creating an app in the LinkedIn Developer Portal.
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_REDIRECT_URI=http://127.0.0.1:5000/auth/linkedin/callback

# ==============================================================================
# FLASK BACKEND CONFIGURATION
# ==============================================================================
# Cryptographic key used for securely signing session cookies.
SECRET_KEY=your-flask-secret-key

# ==============================================================================
# MYSQL DATABASE CONNECTION
# ==============================================================================
# Credentials for the cloud/local MySQL database storing alumni profiles.
# Scraper logic will fall back to local SQLite if this is unavailable.
MYSQLHOST=your-mysql-host
MYSQLUSER=your-mysql-user
MYSQLPASSWORD=your-mysql-password
MYSQL_DATABASE=your-database-name
MYSQLPORT=37157

# ==============================================================================
# ARTIFICIAL INTELLIGENCE ENGINES
# ==============================================================================
# Required for running relevance scoring, degree/major normalization, and parsing.
GROQ_API_KEY=your-groq-key
USE_GROQ=true
GROQ_MODEL=llama-3.1-8b-instant

# ==============================================================================
# EXA / ETL PIPELINE (OPTIONAL OVERRIDES)
# ==============================================================================
# Required for exa.py gather stage.
EXA_API_KEY=your-exa-key

# Optional file paths for exa.py / exa_groq.py
EXA_RAW_CSV_FILE=raw_alumni_data.csv
EXA_FINAL_CSV_FILE=final_alumni_clean.csv
EXA_SEEN_URLS_FILE=seen_urls.txt

# Optional exa_groq.py runtime tuning
EXA_GROQ_MODEL=
EXA_GROQ_FALLBACK_MODELS=
EXA_GROQ_TIMEOUT_SECONDS=45
EXA_GROQ_MAX_RETRIES=3
EXA_GROQ_LOG_EVERY=10
